{
  "name": "zhishare",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"require('fs').rmSync('.next',{ recursive: true, force: true })\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "capture:homepage": "node scripts/capture-homepage.mjs",
    "capture:tools": "node scripts/capture-tools.mjs",
    "capture:tool-detail": "node scripts/capture-tool-detail.mjs",
    "capture:articles": "node scripts/capture-articles.mjs",
    "capture:public-pages": "node scripts/capture-public-pages.mjs",
    "covers:check": "node scripts/checks/check-tool-cover.mjs",
    "covers:bucket:dry-run": "node scripts/content-import/create-tool-covers-bucket.mjs",
    "covers:bucket:execute": "node scripts/content-import/create-tool-covers-bucket.mjs --execute",
    "covers:backfill:dry-run": "node scripts/content-import/backfill-tool-covers.mjs",
    "covers:backfill:execute": "node scripts/content-import/backfill-tool-covers.mjs --execute",
    "covers:photos:dry-run": "node scripts/content-import/fetch-tool-photos.mjs",
    "covers:photos:execute": "node scripts/content-import/fetch-tool-photos.mjs --execute",
    "content:next-7:dry-run": "node scripts/content-import/import-next-7-tools.mjs",
    "content:next-7:execute": "node scripts/content-import/import-next-7-tools.mjs --execute",
    "media:bucket:execute": "node scripts/content-import/create-tool-media-bucket.mjs --execute",
    "article-covers:bucket:execute": "node scripts/content-import/create-article-covers-bucket.mjs --execute",
    "article-covers:backfill:dry-run": "node scripts/content-import/backfill-article-covers.mjs",
    "article-covers:backfill:execute": "node scripts/content-import/backfill-article-covers.mjs --execute",
    "media:import:dry-run": "node scripts/content-import/import-tool-media.mjs",
    "media:import:execute": "node scripts/content-import/import-tool-media.mjs --execute",
    "content:tools-import:dry-run": "node scripts/content-import/import-tools-staged.mjs --input docs/content/bulk-tools-staged-v1.csv --report docs/content/bulk-tools-import-dry-run-report-v1.json",
    "content:tools-ready-import:dry-run": "node scripts/content-import/prepare-tools-ready-import.mjs --input docs/content/bulk-tools-first-10-ready-to-publish-v1.csv --risk docs/content/bulk-tools-first-10-publish-risk-notes-v1.csv --report docs/content/first-10-tools-supabase-import-dry-run-report-v1.json",
    "content:first-3-tools-import:dry-run": "node scripts/content-import/import-first-3-tools.mjs --input docs/content/first-3-tools-ready-to-import-v1.csv --report docs/content/first-3-tools-import-dry-run-report-v1.json",
    "content:first-3-tools-import:readiness": "node scripts/content-import/check-first-3-tools-import-readiness.mjs --input docs/content/first-3-tools-ready-to-import-v1.csv --report docs/content/first-3-tools-import-readiness-report-v1.json",
    "content:pipeline": "py -3 scripts/content-pipeline/content_pipeline.py --source-file scripts/content-pipeline/sources.example.json --output .tmp/content-items.json",
    "content:feishu-export": "py -3 scripts/content-pipeline/feishu_export.py --input .tmp/content-items.json --output .tmp/feishu-payload.json",
    "content:feishu-sync": "py -3 scripts/content-pipeline/feishu_sync.py --input .tmp/feishu-payload.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  }
}
